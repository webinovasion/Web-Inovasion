---
import { footerMenus, type FooterPage } from '../config/Footer';

interface Props {
  page?: FooterPage;
}

const { page = 'home' } = Astro.props;

const currentYear = new Date().getFullYear();

const { heading, services, quickLinks } = footerMenus[page];

const socials = [
  {
    label: 'Instagram Web Inovasion',
    href: 'https://instagram.com/webinovasion',
    icon: `<rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>`,
  },
  {
    label: 'WhatsApp Web Inovasion',
    href: 'https://wa.me/6285881582774',
    icon: `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>`,
  },
  {
    label: 'LinkedIn Founder Web Inovasion',
    href: 'https://www.linkedin.com/in/rayhan-nurahman-1b29a2300/',
    icon: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>`,
  },
];
---

<footer class="bg-ink-primary text-ink-disabled">
  <div class="container-custom pt-14 pb-8">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10
                border-b border-white/[0.07] pb-10"
    >
      <section>
        <a
          href="/"
          aria-label="Web Inovasion"
          class="inline-flex items-center gap-2 mb-4
                 text-lg font-extrabold tracking-tight text-white"
        >
          <span class="h-2 w-2 rounded-full bg-brand-light" aria-hidden="true"></span>

          Web Inovasion
        </a>

        <p class="text-sm leading-relaxed text-ink-muted mb-4">
          Web Inovasion membantu bisnis, UMKM, dan perusahaan membangun website profesional yang cepat, mobile-friendly,
          dan teroptimasi SEO.
        </p>

        <p class="text-xs leading-relaxed text-ink-muted mb-5">
          Konsultasi gratis untuk kebutuhan website bisnis, UMKM, dan perusahaan di seluruh Indonesia.
        </p>

        <div class="flex gap-2">
          {
            socials.map(({ label, href, icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer me"
                aria-label={label}
                class="flex h-8 w-8 items-center justify-center
                     rounded-lg
                     border border-white/[0.08]
                     bg-white/[0.04]
                     text-ink-muted
                     transition-all
                     hover:border-brand-light/40
                     hover:bg-brand-light/10
                     hover:text-brand-light"
              >
                <svg
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={icon}
                />
              </a>
            ))
          }
        </div>
      </section>

      <nav aria-label="Layanan">
        <p class="mb-4 text-xs font-bold uppercase tracking-widest text-white">{heading}</p>

        <ul class="space-y-2.5">
          {
            services.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-ink-muted
               transition-colors
               hover:text-brand-light"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Navigasi">
        <p class="mb-4 text-xs font-bold uppercase tracking-widest text-white">Navigasi</p>

        <ul class="space-y-2.5">
          {
            quickLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-ink-muted
                       transition-colors
                       hover:text-brand-light"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <section>
        <p class="mb-4 text-xs font-bold uppercase tracking-widest text-white">Kontak</p>

        <ul class="space-y-2.5 mb-6">
          <li>
            <a
              href="https://wa.me/6285881582774"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-ink-muted
                     transition-colors
                     hover:text-brand-light"
            >
              WhatsApp
            </a>
          </li>

          <li>
            <a
              href="mailto:websiteinovasion@gmail.com"
              class="text-sm text-ink-muted
                     transition-colors
                     hover:text-brand-light"
            >
              websiteinovasion@gmail.com
            </a>
          </li>
        </ul>

        <p class="mb-2 text-xs font-bold uppercase tracking-widest text-white">Lokasi</p>

        <address class="not-italic text-sm leading-relaxed text-ink-muted">
          Bekasi, Jawa Barat

          <br />

          Melayani seluruh Indonesia
        </address>
      </section>
    </div>

    <div
      class="flex flex-col sm:flex-row
                items-start sm:items-center
                justify-between
                gap-3
                pt-7"
    >
      <p class="text-xs text-ink-muted">
        © {currentYear}

        <span class="font-medium text-brand-light"> Web Inovasion </span>

        . Semua hak dilindungi.
      </p>

      <p class="text-[11px] text-slate-600">Website Profesional • SEO Friendly • Mobile Responsive</p>
    </div>
  </div>
</footer>
