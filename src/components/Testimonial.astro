---
import testimonials from "../data/Testimonials.json";

// Helper: bold-kan highlight text di dalam quote
function formatQuote(quote: string, highlight: string): string {
  if (!highlight) return quote;
  return quote.replace(highlight, `<strong class="font-semibold not-italic text-ink-primary">${highlight}</strong>`);
}

// SVG bintang — reusable
const starPath = `M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z`;
const quotePath = `M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zM15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z`;
---

<section
  id="testimonials"
  aria-labelledby="testimonials-heading"
  class="py-20 lg:py-28 bg-surface-raised"
>
  <div class="container-custom">

    <!-- Section header -->
    <div class="inline-flex items-center gap-1.5 rounded-full
                border border-brand-border bg-brand-muted
                px-3 py-1 mb-4">
      <span class="text-[11px] font-bold tracking-widest text-brand uppercase">
        Testimoni
      </span>
    </div>

    <h2
      id="testimonials-heading"
      class="text-3xl lg:text-4xl font-extrabold tracking-tight
             text-ink-primary leading-tight mb-3"
    >
      Kata Mereka tentang Kami
    </h2>

    <p class="text-base text-ink-secondary leading-relaxed max-w-xl mb-12">
      Kepercayaan klien adalah prioritas utama kami
      di setiap project yang dikerjakan.
    </p>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {testimonials.map((t) => (
        <figure
          class:list={[
            "group flex flex-col gap-5 rounded-2xl border p-7",
            "transition-all duration-300",
            "hover:-translate-y-0.5 hover:shadow-glow-sm",
            t.featured
              ? "border-brand-border bg-surface-raised shadow-card"
              : "border-surface-border bg-surface-base hover:border-brand/25",
          ]}
        >
          <!-- Top row: quote icon + stars -->
          <div class="flex items-start justify-between gap-3">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center
                        rounded-lg bg-brand-muted">
              <svg
                width="16" height="16" viewBox="0 0 24 24"
                fill="#0F766E" aria-hidden="true"
              >
                <path d={quotePath}/>
              </svg>
            </div>

            <!-- Star rating -->
            <div class="flex gap-0.5" aria-label="Rating 5 dari 5 bintang">
              {Array.from({ length: 5 }).map(() => (
                <svg
                  width="13" height="13" viewBox="0 0 24 24"
                  fill="#F59E0B" aria-hidden="true"
                >
                  <path d={starPath}/>
                </svg>
              ))}
            </div>
          </div>

          <!-- Quote -->
          <blockquote
            class="flex-1 text-sm italic leading-[1.8] text-ink-secondary"
            set:html={`"${formatQuote(t.quote, t.highlight)}"`}
          />

          <div class="h-px bg-surface-card"></div>

          <!-- Author -->
          <figcaption class="flex items-center gap-3">
            <div
              class:list={[
                "flex h-10 w-10 flex-shrink-0 items-center justify-center",
                "rounded-full bg-gradient-to-br text-[13px] font-bold text-white",
                t.avatarColor,
              ]}
              aria-hidden="true"
            >
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-bold text-ink-primary">{t.name}</p>
              <p class="text-xs text-ink-secondary mt-0.5">{t.role}</p>
              <p class="text-[11px] text-ink-disabled mt-0.5">{t.company}</p>
            </div>
          </figcaption>

        </figure>
      ))}
    </div>

  </div>
</section>