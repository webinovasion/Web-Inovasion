---
// Data trust signal — update sesuai realita
const stats = [
  { value: "20+", label: "Project Selesai" },
  { value: "<2s", label: "Load Time" },
];
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="py-20 lg:py-28 bg-hero overflow-hidden"
>
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- ── Konten kiri ───────────────────── -->
      <div class="animate-fade-up">

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 rounded-full
                    border border-brand-border bg-brand-muted
                    px-3 py-1.5 mb-6">
          <span class="block h-1.5 w-1.5 rounded-full bg-brand animate-pulse-slow"
                aria-hidden="true"></span>
          <span class="text-xs font-semibold text-brand tracking-wide">
            Solusi Website Modern
          </span>
        </div>

        <!-- H1 — satu per halaman, keyword di depan -->
        <h1
          id="hero-heading"
          class="text-4xl lg:text-5xl xl:text-[3.25rem]
                 font-extrabold leading-[1.1] tracking-tight
                 text-ink-primary"
        >
          Website Profesional<br>
          untuk <em class="not-italic text-brand">Kembangkan</em><br>
          Bisnis Anda
        </h1>

        <p class="mt-5 text-base leading-relaxed text-ink-secondary max-w-lg">
          Web Inovasion membangun website modern, cepat, dan teroptimasi
          untuk bisnis, UMKM, dan perusahaan yang ingin hadir kuat di digital.
        </p>

        <!-- CTA buttons -->
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="#contact"
            class="inline-flex items-center gap-2 rounded-xl
                   bg-brand px-5 py-3 text-sm font-semibold text-white
                   transition hover:bg-brand-hover group"
          >
            Konsultasi Gratis
            <!-- Arrow right SVG -->
            <svg
              width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round"
              class="transition-transform group-hover:translate-x-1"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>

          <a
            href="#portfolio"
            class="inline-flex items-center gap-2 rounded-xl
                   border border-surface-border bg-surface-raised
                   px-5 py-3 text-sm font-medium text-ink-primary
                   transition hover:border-brand hover:text-brand"
          >
            Lihat Portfolio
            <svg
              width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        </div>

        <!-- Trust signal -->
        <div class="mt-10 flex items-center gap-4">
          <!-- Avatar stack -->
          <div class="flex" aria-hidden="true">
            {["AB", "CD", "EF"].map((initials, i) => (
              <div
                class="flex h-8 w-8 items-center justify-center rounded-full
                       border-2 border-surface-base bg-brand text-[11px]
                       font-bold text-white"
                style={i > 0 ? "margin-left: -8px" : ""}
              >
                {initials}
              </div>
            ))}
          </div>
          <p class="text-xs text-ink-muted leading-snug">
            <strong class="font-semibold text-ink-primary">20+ klien puas</strong><br>
            dari berbagai industri
          </p>
        </div>

      </div>

      <!-- ── Visual kanan ──────────────────── -->
      <div
        class="hidden lg:flex items-center justify-center
               relative animate-fade-in"
        aria-hidden="true"
      >
        <!-- Background circle dekoratif -->
        <div class="absolute h-80 w-80 rounded-full bg-brand-glow"></div>

        <!-- Floating badge -->
        <div
          class="absolute -top-3 right-0 z-10 flex items-center gap-2.5
                 rounded-xl border border-surface-border bg-surface-raised
                 px-3.5 py-2.5 shadow-card animate-float"
        >
          <div class="flex h-7 w-7 items-center justify-center
                      rounded-lg bg-success/10 flex-shrink-0">
            <!-- Checkmark SVG -->
            <svg
              width="13" height="13" viewBox="0 0 24 24" fill="none"
              stroke="#10B981" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round"
            >
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div>
            <p class="text-[11px] font-semibold text-ink-primary">Project Selesai</p>
            <p class="text-[10px] text-ink-disabled mt-0.5">2 hari lebih cepat</p>
          </div>
        </div>

        <!-- Card Lighthouse scores -->
        <div class="relative z-[1] w-full max-w-[340px] rounded-2xl
                    border border-surface-border bg-surface-raised p-6 shadow-card">

          <div class="mb-5 flex items-center justify-between">
            <span class="text-sm font-semibold text-ink-primary">Performa Website</span>
            <span class="rounded-full bg-brand-muted px-2.5 py-0.5
                         text-[11px] font-semibold text-brand">Live</span>
          </div>

          <!-- Score bars -->
          {[
            { label: "Performance", value: 98 },
            { label: "SEO", value: 100 },
            { label: "Accessibility", value: 95 },
            { label: "Best Practices", value: 100 },
          ].map(({ label, value }) => (
            <div class="mb-3.5 last:mb-0">
              <div class="mb-1.5 flex justify-between">
                <span class="text-xs text-ink-secondary">{label}</span>
                <span class="text-xs font-semibold text-ink-primary">{value}</span>
              </div>
              <div class="h-1.5 overflow-hidden rounded-full bg-surface-card">
                <div
                  class="h-full rounded-full bg-brand"
                  style={`width: ${value}%`}
                ></div>
              </div>
            </div>
          ))}

          <!-- Stats bottom -->
          <div class="mt-5 grid grid-cols-2 gap-2.5
                      border-t border-surface-card pt-5">
            {stats.map(({ value, label }) => (
              <div class="text-center">
                <p class="text-2xl font-extrabold tracking-tight text-brand">
                  {value}
                </p>
                <p class="mt-0.5 text-[11px] text-ink-disabled">{label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>