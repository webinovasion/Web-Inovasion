<section
  id="cta"
  aria-labelledby="cta-heading"
  class="py-20 lg:py-28 bg-surface-base"
>
  <div class="container-custom">
    <div
      class="relative overflow-hidden rounded-4xl bg-brand
             p-10 md:p-16
             grid grid-cols-1 md:grid-cols-[1fr_auto] gap-10
             items-center"
    >
      <!-- Dekorasi lingkaran — aria-hidden -->
      <div class="absolute -right-16 -top-16 h-72 w-72 rounded-full
                  bg-white/[0.04]" aria-hidden="true"></div>
      <div class="absolute -bottom-20 -left-10 h-60 w-60 rounded-full
                  bg-white/[0.03]" aria-hidden="true"></div>

      <!-- Teks -->
      <div class="relative z-10">
        <p class="mb-3 text-[11px] font-bold uppercase tracking-[0.1em]
                  text-white/60">
          Mulai Sekarang
        </p>
        <h2
          id="cta-heading"
          class="text-3xl lg:text-4xl font-extrabold leading-tight
                 tracking-tight text-white mb-3"
        >
          Siap Bangun Website<br>
          yang Benar-Benar Bekerja?
        </h2>
        <p class="text-base text-white/70 leading-relaxed max-w-lg">
          Konsultasikan kebutuhan Anda — gratis, tanpa komitmen.
          Kami bantu tentukan solusi yang tepat untuk bisnis Anda.
        </p>
      </div>

      <!-- Buttons -->
      <div class="relative z-10 flex flex-col gap-3 flex-shrink-0">
        <a
          href="#contact"
          class="inline-flex items-center justify-center gap-2
                 rounded-xl bg-white px-6 py-3.5
                 text-sm font-bold text-brand
                 transition-colors hover:bg-teal-50"
        >
          Konsultasi Gratis
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a
          href="#portfolio"
          class="inline-flex items-center justify-center
                 rounded-xl border border-white/25 px-6 py-3.5
                 text-sm font-medium text-white
                 transition-colors hover:bg-white/8"
        >
          Lihat Portfolio
        </a>
      </div>

    </div>
  </div>
</section>