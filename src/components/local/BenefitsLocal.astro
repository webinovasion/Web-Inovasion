---
import type { LocalPage } from "../../config/LocalPage";

interface Props {
  page: LocalPage;
}

const { page } = Astro.props;

// Icon map — tambah key baru kalau perlu icon lain
const icons: Record<string, string> = {
  rocket: `<path d="M4.5 16.5c-1.5 1.5-2 5-2 5s3.5-.5 5-2c.8-.8.8-2.2 0-3-.8-.8-2.2-.8-3 0z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>`,
  search: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  smartphone: `<rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/>`,
  headset: `<path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/><path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>`,
  code: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
};
---

<section
  id="benefits"
  aria-labelledby="benefits-heading"
  class="py-24 bg-surface-base"
>
  <div class="container-custom">

    <!-- Heading -->
    <div class="mx-auto max-w-3xl text-center">
      <span
        class="inline-flex items-center rounded-full
               border border-brand-border bg-brand-muted
               px-4 py-2 text-sm font-medium text-brand"
      >
        Mengapa Memilih Kami?
      </span>

      <h2
        id="benefits-heading"
        class="mt-5 text-3xl font-extrabold tracking-tight
               text-ink-primary md:text-4xl"
      >
        Solusi Website Profesional untuk Bisnis di {page.city}
      </h2>

      <p class="mt-5 text-lg leading-relaxed text-ink-secondary">
        Kami membangun website yang bukan hanya menarik secara visual,
        tetapi juga cepat, SEO friendly, dan membantu meningkatkan
        kepercayaan calon pelanggan terhadap bisnis Anda.
      </p>
    </div>

    <!-- Cards -->
    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {page.benefits.map((benefit) => (
        <article
          class="group rounded-3xl border border-surface-border
                 bg-surface-card p-7 transition-all duration-300
                 hover:-translate-y-1 hover:border-brand/30
                 hover:shadow-card"
        >
          <div
            class="mb-5 flex h-14 w-14 items-center justify-center
                   rounded-2xl bg-brand-muted transition-colors
                   duration-300 group-hover:bg-brand/15"
          >
            <svg
              width="26" height="26" viewBox="0 0 24 24"
              fill="none" stroke="#0F766E" stroke-width="1.7"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
              set:html={icons[benefit.icon] ?? icons.code}
            />
          </div>

          <h3 class="text-xl font-bold text-ink-primary">
            {benefit.title}
          </h3>

          <p class="mt-3 leading-relaxed text-ink-secondary">
            {benefit.description}
          </p>
        </article>
      ))}
    </div>

  </div>
</section>