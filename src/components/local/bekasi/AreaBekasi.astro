---
const areas = [
  'Bekasi Barat',
  'Bekasi Timur',
  'Bekasi Selatan',
  'Bekasi Utara',
  'Jatiasih',
  'Jatisampurna',
  'Rawalumbu',
  'Mustika Jaya',
  'Pondok Gede',
  'Medan Satria',
  'Bantargebang',
  'Tambun',
  'Cibitung',
  'Cikarang',
];
---

<section class="py-24 bg-surface-base" id="areas">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto">
      <span class="text-brand text-sm font-medium"> AREA LAYANAN </span>

      <h2 class="mt-3 text-3xl lg:text-4xl font-bold">Melayani Seluruh Wilayah Bekasi</h2>

      <p class="mt-4 text-ink-secondary">
        Web Inovasion membantu UMKM, bisnis, startup, dan perusahaan di berbagai wilayah Bekasi.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-12">
      {
        areas.map((area) => (
          <div class="rounded-2xl border border-surface-border bg-white p-5 text-center shadow-card">{area}</div>
        ))
      }
    </div>
  </div>
</section>
