---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Web Inovasion – Jasa Website Profesional untuk Bisnis & UMKM',
  description = 'Web Inovasion membantu bisnis, UMKM, dan perusahaan membangun website modern, cepat, dan teroptimasi SEO. Melayani company profile, landing page, dan website custom.',
  ogImage = '/assets/images/logo/logo_web_inovasion.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://www.webinovasion.com');

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://www.webinovasion.com/#business',
      name: 'Web Inovasion',
      description:
        'Jasa pembuatan website profesional untuk bisnis, UMKM, dan perusahaan. Melayani company profile, landing page, website custom, dan toko online.',
      url: 'https://www.webinovasion.com',
      telephone: '+6285881582774',
      email: 'websiteinovasion@gmail.com',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Bekasi',
        addressRegion: 'Jawa Barat',
        addressCountry: 'ID',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: -6.3644,
        longitude: 107.1675,
      },
      areaServed: {
        '@type': 'Country',
        name: 'Indonesia',
      },
      priceRange: 'Rp 1.000.000 – Rp 10.000.000',
      openingHours: 'Mo-Sa 08:00-17:00',
      sameAs: ['https://instagram.com/webinovasion', 'https://wa.me/6285881582774'],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Layanan Web Development',
        itemListElement: [
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Website Company Profile',
              description: 'Website profesional multi-halaman untuk meningkatkan kredibilitas bisnis dan perusahaan.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Landing Page',
              description: 'Halaman konversi tinggi yang dirancang untuk meningkatkan penjualan produk atau layanan.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Website UMKM dan Toko Online',
              description: 'Solusi digital untuk UMKM dengan katalog produk dan sistem order via WhatsApp.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Website Custom',
              description: 'Pengembangan sistem web dari nol sesuai kebutuhan operasional dan bisnis klien.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Portfolio Pribadi',
              description: 'Website personal untuk profesional dan freelancer yang ingin membangun personal brand.',
            },
          },
        ],
      },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://www.webinovasion.com/#website',
      url: 'https://www.webinovasion.com',
      name: 'Web Inovasion',
      description: 'Jasa pembuatan website profesional untuk bisnis dan UMKM Indonesia.',
      publisher: {
        '@id': 'https://www.webinovasion.com/#business',
      },
      inLanguage: 'id-ID',
    },
    {
      '@type': 'Person',
      '@id': 'https://www.webinovasion.com/#founder',
      name: 'Nama Kamu',
      jobTitle: 'Web Developer & Designer',
      worksFor: {
        '@id': 'https://www.webinovasion.com/#business',
      },
      url: 'https://www.webinovasion.com',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Bekasi',
        addressRegion: 'Jawa Barat',
        addressCountry: 'ID',
      },
    },
  ],
};
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="Web Inovasion" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/assets/images/logo/logo_web_inovasion.webp" />

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <title>{title}</title>
  </head>

  <body class="bg-surface-base text-ink-primary font-sans antialiased">
    <slot />
  </body>
</html>
