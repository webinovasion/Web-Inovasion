---
import BaseLayout from "../layouts/BaseLayout.astro";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import HeroLocal from "../components/local/HeroLocal.astro";
import BenefitsLocal from "../components/local/BenefitsLocal.astro";
import CoverageArea from "../components/local/CoverageArea.astro";

import Services from "../components/ServiceCard.astro";
import Pricing from "../components/Pricing.astro";
import Portfolio from "../components/ProjectCard.astro";
import Testimonial from "../components/Testimonial.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Contact from "../components/Contact.astro";

import { localPages } from "../config/LocalPage";

const page = localPages.bekasi;
---

<BaseLayout
  title={page.title}
  description={page.description}
>

  <Header page={page.navigation} />

  <main>

    <HeroLocal page={page} />

    <BenefitsLocal page={page} />

    <CoverageArea page={page} />

    <Services />

    <Pricing />

    <Portfolio />

    <Testimonial />

    <FAQ />

    <CTA />

    <Contact />

  </main>

  <Footer page={page.footer} />

</BaseLayout>